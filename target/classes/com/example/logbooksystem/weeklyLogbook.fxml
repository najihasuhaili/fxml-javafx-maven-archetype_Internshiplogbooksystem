<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="800.0" prefWidth="1000.0" style="-fx-background-color: #f8f4f1;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.logbooksystem.controller.WeeklyLogbookController">

    <children>

        <!-- TOP HEADER -->
        <Pane layoutX="0.0" layoutY="0.0" prefHeight="70.0" prefWidth="980.0" style="-fx-background-color: #6f4e37;">
            <children>
                <Label layoutX="25.0" layoutY="18.0" text="Internship Logbook Management System" textFill="WHITE">
                    <font>
                        <Font name="Arial Bold" size="24.0" />
                    </font>
                </Label>

                <Button fx:id="btnBack" layoutX="790.0" layoutY="18.0" mnemonicParsing="false" onAction="#handleBack" prefHeight="32.0" prefWidth="70.0" style="-fx-background-color: white; -fx-text-fill: #6f4e37; -fx-background-radius: 8;" text="Back" />

                <Button fx:id="btnLogout" layoutX="875.0" layoutY="18.0" mnemonicParsing="false" onAction="#handleLogout" prefHeight="32.0" prefWidth="80.0" style="-fx-background-color: white; -fx-text-fill: #6f4e37; -fx-background-radius: 8;" text="Logout" />
            </children>
        </Pane>

        <!-- TITLE -->
        <Label layoutX="32.0" layoutY="95.0" text="Weekly Logbook Entry" textFill="#4a3426">
            <font>
                <Font name="Arial Bold" size="28.0" />
            </font>
        </Label>

        <Label fx:id="lblWeekTitle" layoutX="35.0" layoutY="135.0" text="Week 1" textFill="#7a5c49">
            <font>
                <Font name="Arial Bold" size="18.0" />
            </font>
        </Label>

        <!-- FORM SECTION -->
        <Pane layoutX="31.0" layoutY="175.0" prefHeight="250.0" prefWidth="918.0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #d8c2b0; -fx-border-radius: 12;">
            <children>

                <Label layoutX="25.0" layoutY="22.0" text="Day:" textFill="#4a3426" />
                <ComboBox fx:id="cbDay" layoutX="110.0" layoutY="18.0" prefHeight="26.0" prefWidth="180.0" promptText="Select Day" />

                <Label layoutX="330.0" layoutY="22.0" text="Date:" textFill="#4a3426" />
                <DatePicker fx:id="dpDate" layoutX="390.0" layoutY="18.0" prefHeight="26.0" prefWidth="180.0" />

                <Label layoutX="610.0" layoutY="22.0" text="Status:" textFill="#4a3426" />
                <ComboBox fx:id="cbStatus" layoutX="670.0" layoutY="18.0" prefHeight="26.0" prefWidth="180.0" promptText="Select Status" />

                <Label layoutX="25.0" layoutY="70.0" text="Activity / Task:" textFill="#4a3426" />
                <TextArea fx:id="txtActivity" layoutX="110.0" layoutY="66.0" prefHeight="70.0" prefWidth="740.0" promptText="Enter activity or task done on that day..." wrapText="true" />

                <Label layoutX="25.0" layoutY="155.0" text="Remarks:" textFill="#4a3426" />
                <TextArea fx:id="txtRemarks" layoutX="110.0" layoutY="151.0" prefHeight="55.0" prefWidth="740.0" promptText="Enter remarks or additional notes..." wrapText="true" />

                <Button fx:id="btnAdd" layoutX="110.0" layoutY="217.0" mnemonicParsing="false" onAction="#handleAdd" prefHeight="30.0" prefWidth="90.0" style="-fx-background-color: #8b5e3c; -fx-text-fill: white; -fx-background-radius: 8;" text="Add" />

                <Button fx:id="btnUpdate" layoutX="215.0" layoutY="217.0" mnemonicParsing="false" onAction="#handleUpdate" prefHeight="30.0" prefWidth="90.0" style="-fx-background-color: #a47148; -fx-text-fill: white; -fx-background-radius: 8;" text="Update" />

                <Button fx:id="btnDelete" layoutX="320.0" layoutY="217.0" mnemonicParsing="false" onAction="#handleDelete" prefHeight="30.0" prefWidth="90.0" style="-fx-background-color: #b85c38; -fx-text-fill: white; -fx-background-radius: 8;" text="Delete" />

                <Button fx:id="btnClear" layoutX="425.0" layoutY="217.0" mnemonicParsing="false" onAction="#handleClear" prefHeight="30.0" prefWidth="90.0" style="-fx-background-color: #d9b08c; -fx-text-fill: #3d2b1f; -fx-background-radius: 8;" text="Clear" />

            </children>
        </Pane>

        <!-- TABLE SECTION -->
        <Label layoutX="35.0" layoutY="450.0" text="Weekly Records" textFill="#4a3426">
            <font>
                <Font name="Arial Bold" size="20.0" />
            </font>
        </Label>

        <TableView fx:id="tableLogbook" layoutX="32.0" layoutY="485.0" prefHeight="292.0" prefWidth="918.0">
            <columns>
                <TableColumn fx:id="colDay" prefWidth="90.39999008178711" text="Day" />
                <TableColumn fx:id="colDate" prefWidth="44.0" text="Date" />
                <TableColumn fx:id="colActivity" prefWidth="145.59999084472656" text="Activity / Task" />
                <TableColumn fx:id="colRemarks" prefWidth="125.60003662109375" text="Remarks" />
                <TableColumn fx:id="colStatus" minWidth="0.0" prefWidth="102.39999389648438" text="Status" />
                <TableColumn fx:id="colLecturerComment" prefWidth="492.0" text="Lecturer Comment" />
                <TableColumn fx:id="colSignature" prefWidth="250.0" text="Signature" />
            </columns>
        </TableView>

    </children>
</AnchorPane>
