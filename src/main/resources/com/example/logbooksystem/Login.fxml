<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="650.0" prefWidth="900.0" style="-fx-background-color: f4e6dd;" 
            xmlns="http://javafx.com/javafx/25" 
            xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="com.example.logbooksystem.controller.LoginController">
    <children>
      <ImageView fitHeight="652.0" fitWidth="900.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@bg-login%20(2).png" />
         </image>
      </ImageView>
        <Label layoutX="288.0" layoutY="255.0" text="ID: " />
        <TextField fx:id="txtId" layoutX="368.0" layoutY="251.0" prefHeight="26.0" prefWidth="254.0">
         <tooltip>
            <Tooltip text="enter id" />
         </tooltip></TextField>

        <Label layoutX="288.0" layoutY="295.0" text="Password:" />
        <PasswordField fx:id="txtPassword" layoutX="368.0" layoutY="291.0" prefWidth="200">
         <tooltip>
            <Tooltip text="default password : &quot;123&quot;" />
         </tooltip></PasswordField>

        <Button fx:id="btnLogin" layoutX="288.0" layoutY="409.0" 
                onAction="#handleLogin" prefHeight="26.0" 
                prefWidth="349.0" style="-fx-background-color: brown;" 
                text="Login" textFill="#fffcfc" />

        <Label fx:id="lblMessage" layoutX="150" layoutY="200" textFill="red" />
      <Label layoutX="171.0" layoutY="93.0" prefHeight="59.0" prefWidth="558.0" text="STUDENT INTERNSHP LOGBOOK ">
         <font>
            <Font name="Arial Black" size="30.0" />
         </font>
      </Label>
      <Label layoutX="243.0" layoutY="152.0" prefHeight="46.0" prefWidth="413.0" text="MANAGEMENT SYSTEM">
         <font>
            <Font name="Arial Black" size="30.0" />
         </font>
      </Label>
    </children>
</AnchorPane>
